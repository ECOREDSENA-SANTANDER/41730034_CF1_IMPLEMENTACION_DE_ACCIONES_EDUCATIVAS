s, promoviendo la articulación intersectorial y la implementación de políticas públicas basadas en la equidad y el bienestar integral. A continuación, se presenta el mapa conceptual de los actores estratégicos de entornos saludables (EES). \")])\n},function (){var _vm=this,_c=_vm._self._c;return _c('div',{staticClass:\"row justify-content-center mt-5\",attrs:{\"data-aos\":\"fade-left\"}},[_c('div',{staticClass:\"col-lg-10 col-sm-12 col-md-12\"},[_c('div',{staticClass:\"titulo-sexto color-acento-contenido\"},[_c('h5',[_vm._v(\"Figura 2. \")]),_vm._v(\"Actores estratégicos de EES\")]),_c('figure',[_c('img',{attrs:{\"src\":require(\"@/assets/curso/temas/t1/fig2.png\"),\"alt\":\"Mapa conceptual de los actores de la Estrategia de entornos saludables (EES), que muestra la relación entre entidades como ministerios, instituciones educativas y organizaciones sociales en la promoción de entornos saludables.\"}})])])])\n}]\n\nexport { render, staticRenderFns }"],"mappings":"AAAA,IAAIA,MAAM,GAAG,SAASA,MAAMA,CAAA,EAAE;EAAC,IAAIC,GAAG,GAAC,IAAI;IAACC,EAAE,GAACD,GAAG,CAACE,KAAK,CAACD,EAAE;EAAC,OAAOA,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAA2B,CAAC,EAAC,CAACF,EAAE,CAAC,eAAe,CAAC,EAACA,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAAmD,CAAC,EAAC,CAACH,GAAG,CAACI,EAAE,CAAC,CAAC,CAAC,EAACJ,GAAG,CAACI,EAAE,CAAC,CAAC,CAAC,EAACH,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAAoD,CAAC,EAAC,CAACH,GAAG,CAACI,EAAE,CAAC,CAAC,CAAC,EAACH,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAA8B,CAAC,EAAC,CAACF,EAAE,CAAC,WAAW,EAAC;IAACI,KAAK,EAAC;MAAC,MAAM,EAAC,GAAG;MAAC,eAAe,EAAC;IAAuB;EAAC,CAAC,EAAC,CAACJ,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC,sBAAsB;IAACE,KAAK,EAAC;MAAC,QAAQ,EAAC;IAAS;EAAC,CAAC,EAAC,CAACJ,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC,+CAA+C;IAACE,KAAK,EAAC;MAAC,UAAU,EAAC;IAAY;EAAC,CAAC,EAAC,CAACJ,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC;EAAW,CAAC,EAAC,CAACF,EAAE,CAAC,GAAG,EAAC;IAACE,WAAW,EAAC;EAAM,CAAC,EAAC,CAACH,GAAG,CAACM,EAAE,CAAC,iNAAiN,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAACL,EAAE,CAAC,KAAK,EAAC;IAACE,WAAW,EAAC,sB